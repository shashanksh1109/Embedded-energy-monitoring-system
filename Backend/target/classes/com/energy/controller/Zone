package com.energy.controller;

import com.energy.dto.ZoneResponse;
import com.energy.service.ZoneService;
import lombok.RequiredArgsConstructor;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import java.util.List;

/**
 * ZoneController - HTTP endpoints for zone data
 *
 * @RestController = this class handles HTTP requests
 *                   and returns JSON automatically.
 *                   Combination of @Controller + @ResponseBody.
 *
 * @RequestMapping("/api/zones") = every endpoint in this
 *   class starts with /api/zones
 *
 * @RequiredArgsConstructor = Lombok injects ZoneService
 */
@RestController
@RequestMapping("/api/zones")
@RequiredArgsConstructor
public class ZoneController {

    private final ZoneService zoneService;

    /**
     * GET /api/zones
     *
     * Returns all zones in the system.
     *
     * ResponseEntity<List<ZoneResponse>>
     *   ResponseEntity = HTTP response wrapper
     *   List<ZoneResponse> = the body of the response
     *
     * .ok() = HTTP status 200
     *
     * Example response:
     * [
     *   { "id": "...", "name": "Zone_A", "description": "Conference Room", ... },
     *   { "id": "...", "name": "Zone_B", "description": "Executive Office", ... }
     * ]
     */
    @GetMapping
    public ResponseEntity<List<ZoneResponse>> getAllZones() {
        return ResponseEntity.ok(zoneService.getAllZones());
    }

    /**
     * GET /api/zones/Zone_A
     *
     * Returns one zone by name.
     *
     * @PathVariable extracts "Zone_A" from the URL path.
     * Spring maps {name} in the path to the name parameter.
     *
     * If zone not found, service throws RuntimeException
     * which returns HTTP 500 for now.
     * We will handle this properly with @ExceptionHandler later.
     */
    @GetMapping("/{name}")
    public ResponseEntity<ZoneResponse> getZoneByName(
        @PathVariable String name
    ) {
        return ResponseEntity.ok(zoneService.getZoneByName(name));
    }

}